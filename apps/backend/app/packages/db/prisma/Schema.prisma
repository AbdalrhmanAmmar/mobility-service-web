generator client {
  provider = "prisma-client"  // بدل prisma-client-js
  output   = "./generated/prisma" // أصبح إجبارياً الآن
}

datasource db {
  provider = "postgresql"
}



model vin{
  id        String  @id @default(uuid())
  vin       String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}